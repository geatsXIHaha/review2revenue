# ========================================
# Review2Revenue - Complete Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env file with real secrets to git!

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Supabase PostgreSQL Connection
# Format: postgresql://user:password@host:port/database?sslmode=require
DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ========================================
# LLM API CONFIGURATIONS
# ========================================

# Groq API (PRIMARY - Fast inference)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API (SECONDARY - Alternative)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# Z.AI OpenAI-Compatible API (OPTIONAL)
# Get your key from: https://z.ai
ZAI_API_KEY=YOUR_ZAI_API_KEY
ZAI_BASE_URL=https://api.z.ai/v1
ZAI_MODEL=glm-4.5

# ========================================
# BACKEND SERVER CONFIGURATION
# ========================================
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# GOOGLE SERVICES
# ========================================
# Google Places API - For restaurant data enrichment and business hours
# Get your key from: https://console.cloud.google.com/
# Make sure to enable: Places API, Maps JavaScript API
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ========================================
# FIREBASE AUTHENTICATION (FRONTEND)
# ========================================
# Required for Google Sign-In authentication
# Get these values from: https://console.firebase.google.com/
# Steps:
# 1. Create a new Firebase project
# 2. Create a web app in your Firebase project
# 3. Copy the configuration values below

# Firebase Core Configuration
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# ========================================
# FRONTEND SETUP NOTES
# ========================================
# 1. Copy Firebase config to: frontend/.env.local
# 2. Install dependencies: cd frontend && npm install
# 3. Start dev server: npm run dev
# 4. Build for production: npm run build
# ========================================
