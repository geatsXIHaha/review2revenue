# ========================================
# Review2Revenue - Complete Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env file with real secrets to git!

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL connection string
# Supabase PostgreSQL Connection example:
# Format: postgresql://user:password@host:port/database?sslmode=require
DB_URL=postgresql://postgres.sojtwfsaujdzkgyoxlhk:m9BWHQiFLz80QVFo@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# IMPORTANT: This backend DB_URL connects to the restaurant/reviews data
# Separate from frontend's Supabase connection which stores user profiles

# ========================================
# DATABASE SCHEMA - REQUIRED TABLES
# ========================================
# The application expects these tables in PostgreSQL:
#
# restaurants (restaurant data)
# - store_id (TEXT PRIMARY KEY)
# - name (TEXT)
# - food_type (TEXT)
# - avg_rating (NUMERIC)
# - review_count (INTEGER)
# - ... other columns
#
# reviews (customer reviews)
# - id (PRIMARY KEY)
# - store_id (FOREIGN KEY to restaurants)
# - review_text (TEXT)
# - rating (NUMERIC)
# - ... other columns
#
# Load data using: python scripts/load_to_db.py

# ========================================
# LLM API CONFIGURATIONS
# ========================================

# Groq API (PRIMARY - Fast inference)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API (SECONDARY - Alternative)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# Z.AI OpenAI-Compatible API (OPTIONAL)
# Get your key from: https://z.ai
ZAI_API_KEY=YOUR_ZAI_API_KEY
ZAI_BASE_URL=https://api.z.ai/v1
ZAI_MODEL=glm-4.5

# ========================================
# BACKEND SERVER CONFIGURATION
# ========================================
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# GOOGLE SERVICES
# ========================================
# Google Places API - For restaurant data enrichment and business hours
# Get your key from: https://console.cloud.google.com/
# Make sure to enable: Places API, Maps JavaScript API
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ========================================
# FIREBASE AUTHENTICATION (BACKEND REFERENCE)
# ========================================
# Backend uses Firebase config for verifying auth tokens
# These should match your frontend Firebase config
# Get these values from: https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# ========================================
# ROLE-BASED BACKEND PROCESSING
# ========================================
# The backend now processes requests differently based on role:
#
# DINER REQUESTS:
# - Receive: restaurant_name (string), prompt (string)
# - Backend: Searches restaurants by name, returns metrics + recommendations
# - API: POST /api/ask with role='diner'
#
# VENDOR REQUESTS:
# - Receive: store_id (string), prompt (string), external_reviews (optional)
# - Backend: Uses store_id to fetch restaurant from database
# - Endpoint: GET /api/restaurants/by-store-id?store_id=X
# - Uses find_restaurant_by_store_id() in repository.py
# - Returns business analysis with restaurant-specific context
# - API: POST /api/ask with role='vendor' + store_id field
#
# IMPORTANT: Backend validates store_id against user profile in Supabase

# ========================================
# API ENDPOINTS (NEW & EXISTING)
# ========================================
# GET /health
#   Health check endpoint
#   Returns: {"status": "ok"}
#
# GET /api/restaurants/search?query=<name>&limit=<num>
#   Search restaurants by name (used by diners during search)
#   Params: query (string, min 1), limit (int, default 8, max 20)
#   Returns: {"restaurants": [list of restaurant objects]}
#
# GET /api/restaurants/by-store-id?store_id=<id>
#   Get a specific restaurant by store_id (NEW - used by vendors)
#   Params: store_id (string, required)
#   Returns: {"restaurant": {store_id, name, food_type, avg_rating, ...}}
#   Used in frontend: App.jsx useEffect to fetch vendor's restaurant
#
# POST /api/ask
#   Submit prompt for AI analysis
#   Body: {role, prompt, restaurant_name?, store_id?, external_reviews?}
#   Returns: {response, metadata, sentiment_summary}

# ========================================
# FRONTEND SETUP NOTES
# ========================================
# 1. Copy Firebase config to: frontend/.env.local
# 2. Copy Supabase credentials to: frontend/.env.local
# 3. Install dependencies: cd frontend && npm install
# 4. Start dev server: npm run dev
# 5. Build for production: npm run build
