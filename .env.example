DB_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/review2revenue_db

# Groq settings (primary)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
