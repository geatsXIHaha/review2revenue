# ========================================
# Review2Revenue Frontend - Configuration
# ========================================
# Copy this file to .env.local and fill in your actual values
# SECURITY: Never commit .env.local file with real secrets to git!

# ========================================
# FIREBASE AUTHENTICATION
# ========================================
# Required for Google Sign-In authentication on the frontend
# Get these values from: https://console.firebase.google.com/

# Steps to get Firebase config:
# 1. Go to Firebase Console: https://console.firebase.google.com/
# 2. Create a new project or select existing one
# 3. Click on "Web" icon to create a web app
# 4. Copy the firebaseConfig object values below:

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# ========================================
# SUPABASE DATABASE CONFIGURATION
# ========================================
# Required for user profile storage and restaurant database queries
# Handles:
# - User role management (diner vs vendor)
# - Vendor store_id assignment
# - User profile lookups after registration
# Get these values from: https://app.supabase.com/

# Steps to get Supabase credentials:
# 1. Go to Supabase Dashboard: https://app.supabase.com/
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and Anon Key below:

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ========================================
# ROLE-BASED ACCESS CONTROL
# ========================================
# The application implements permanent role selection:
#
# DINER ROLE (🍴):
# - Can search restaurants by name (optional)
# - Can ask for recommendations
# - Can explore any restaurant in the database
# - No role restrictions on data access
#
# VENDOR ROLE (🏪):
# - Assigned to a specific restaurant via store_id
# - Can ONLY see their assigned restaurant
# - Cannot search or access other restaurants
# - Restaurant name fetched from /api/restaurants/by-store-id endpoint
# - Ask for business insights about their restaurant
#
# PERMANENCE:
# - Role selection during registration is PERMANENT
# - User will see warning: "Once you confirm this role, you CANNOT change it"
# - Role stored in Supabase users.role column
# - Backend validates role for each request

# ========================================
# SUPABASE SCHEMA REQUIREMENTS
# ========================================
# The application requires this table in your Supabase PostgreSQL database:
#
# CREATE TABLE users (
#   id UUID PRIMARY KEY (Firebase UID),
#   email TEXT NOT NULL,
#   user_name TEXT,
#   role TEXT NOT NULL CHECK (role IN ('diner', 'vendor')),
#   store_id TEXT REFERENCES restaurants(store_id),
#   created_at TIMESTAMP DEFAULT now()
# );
#
# The registration flow will automatically INSERT/UPDATE this table
# when a user completes their role selection and restaurant assignment.

# ========================================
# NOTES
# ========================================
# - These variables must start with VITE_ to be accessible in Vite
# - Save this as .env.local (not .env.example)
# - .env.local is gitignored and won't be committed
# - Changes to this file require restarting the dev server
# - The backend .env is separate and handles API keys and DB_URL there
# - Frontend uses Supabase for user profiles, backend uses DB_URL for restaurants
